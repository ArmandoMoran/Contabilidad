# ── Database ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=contabilidad
DB_USER=contabilidad
DB_PASSWORD=contabilidad_dev

# ── JWT ──
JWT_SECRET=dev-only-secret-change-in-production-minimum-256-bits-long-key-here
JWT_ACCESS_EXPIRY_MINUTES=30
JWT_REFRESH_EXPIRY_DAYS=7

# ── Storage (MinIO local) ──
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin123
STORAGE_BUCKET_XML=contabilidad-xml
STORAGE_BUCKET_PDF=contabilidad-pdf
STORAGE_BUCKET_ACUSES=contabilidad-acuses
STORAGE_BUCKET_ATTACHMENTS=contabilidad-attachments

# ── SAT Mode (simulated | sandbox | production) ──
SAT_MODE=simulated
SAT_VALIDATION_URL=http://localhost:8089/sat/v1

# ── PAC Mode (simulated | sandbox | production) ──
PAC_MODE=simulated
PAC_BASE_URL=http://localhost:8089/pac/v1
PAC_USER=
PAC_PASSWORD=

# ── CSD (dummy for local) ──
CSD_CERT_PATH=
CSD_KEY_PATH=
CSD_PASSWORD=

# ── e.firma (disabled in local) ──
EFIRMA_ENABLED=false
EFIRMA_CERT_PATH=
EFIRMA_KEY_PATH=
EFIRMA_PASSWORD=

# ── App ──
APP_BASE_URL=http://localhost:5173

# ── Mail (Mailpit) ──
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=no-reply@contabilidad.local
